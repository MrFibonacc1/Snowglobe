# URL of the automation/ service. When reachable, the dashboard polls
# GET {VITE_AUTOMATION_URL}/events for live events. When it is not, the
# dashboard falls back to a local simulation so it always demos.
VITE_AUTOMATION_URL=http://localhost:8000

# URL of the perception/ detect API (perception/server.py). The Testing page
# uploads an image here to run the vision model. Start it with:
#   uvicorn perception.server:app --port 8008
VITE_PERCEPTION_URL=http://localhost:8008
