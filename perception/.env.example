# Copy to perception/.env (gitignored) or export these in your shell.

# NVIDIA API key for the NIM endpoint (build.nvidia.com). Required unless --mock.
NVIDIA_API_KEY=

# VLM model + endpoint. Defaults target Cosmos 3 Reasoner (Nano) on the hosted
# NIM. Point VLM_BASE_URL at a self-hosted NIM container if you get GPU access,
# and swap VLM_MODEL to the Super reasoner or a Nemotron-VL fallback.
VLM_MODEL=nvidia/cosmos3-nano-reasoner
VLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Where events are POSTed (automation/ service).
AUTOMATION_URL=http://localhost:8000

# Static host for saved frames (perception/snapshot_server.py). Blank → emit
# local file paths instead of URLs.
SNAPSHOT_BASE_URL=http://localhost:8001
