# Copy to perception/.env (gitignored) or export these in your shell.

# NVIDIA API key for the hosted NIM endpoint (build.nvidia.com). Required unless
# --mock, unless you point at a self-hosted endpoint via VLM_API_KEY below.
NVIDIA_API_KEY=

# VLM model + endpoint. Default is a hosted Nemotron-VL model (verified working
# on build.nvidia.com).
VLM_MODEL=nvidia/nemotron-nano-12b-v2-vl
VLM_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Self-hosted Cosmos 3 via Baseten ─────────────────────────────────────────
# Deploy the Cosmos reasoner NIM on Baseten (see deploy/baseten-cosmos3/).
# Then flip perception to use it by uncommenting and filling these in:
#
#   VLM_API_KEY=<your Baseten API key>        # takes precedence over NVIDIA_API_KEY
#   VLM_AUTH_SCHEME=api-key                    # Baseten uses "Api-Key: <key>"
#   VLM_BASE_URL=https://model-<id>.api.baseten.co/environments/production/sync/v1
#   VLM_MODEL=nvidia/cosmos-reason2-8b         # the model id the NIM serves

# Where events are POSTed (automation/ service).
AUTOMATION_URL=http://localhost:8000

# Static host for saved frames (perception/snapshot_server.py). Blank → emit
# local file paths instead of URLs.
SNAPSHOT_BASE_URL=http://localhost:8001
