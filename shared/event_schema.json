{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Snowglobe Event",
  "description": "The contract between perception/ and automation/. Freeze early; extend payload, not the envelope.",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp", "confidence", "location"],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "UUID, generated by perception"
    },
    "event_type": {
      "type": "string",
      "enum": ["spill", "person_count", "foot_traffic", "safety_violation"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "location": {
      "type": "string",
      "description": "Zone identifier, e.g. zone_a"
    },
    "snapshot_url": {
      "type": "string",
      "description": "Path or URL to the frame that triggered the event"
    },
    "payload": {
      "type": "object",
      "description": "Per-event-type detail, e.g. {\"count\": 14} for person_count",
      "additionalProperties": true
    }
  }
}
